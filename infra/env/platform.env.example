# ============================================================
# Unified Streaming Lakehouse Platform
# Example environment configuration for local development
# Copy this file to:
#   infra/env/platform.env
# and adjust values as needed for your environment.
# ============================================================

# ------------------------------------------------------------
# Platform metadata
# ------------------------------------------------------------
PLATFORM_NAME=unified-streaming-lakehouse-platform
PLATFORM_ENV=local
PLATFORM_TIMEZONE=UTC

# ------------------------------------------------------------
# Apache Kafka
# ------------------------------------------------------------
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_NODE_ID=1
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_NUM_PARTITIONS=3
KAFKA_DEFAULT_REPLICATION_FACTOR=1
KAFKA_MIN_INSYNC_REPLICAS=1
KAFKA_AUTO_CREATE_TOPICS=false

KAFKA_TOPIC_USER_ACTIVITY=events.user_activity.v1
KAFKA_TOPIC_ORDERS=events.orders.v1
KAFKA_TOPIC_PAYMENTS=events.payments.v1
KAFKA_TOPIC_DEVICE_TELEMETRY=events.device_telemetry.v1

KAFKA_TOPIC_RETENTION_MS=604800000
KAFKA_TOPIC_SEGMENT_MS=86400000

# ------------------------------------------------------------
# Kafka UI
# ------------------------------------------------------------
KAFKA_UI_HOST=kafka-ui
KAFKA_UI_PORT=8080

# ------------------------------------------------------------
# Event producer
# ------------------------------------------------------------
PRODUCER_APP_NAME=event-producer
PRODUCER_LOG_LEVEL=INFO
PRODUCER_BATCH_SIZE=100
PRODUCER_INTERVAL_MS=1000
PRODUCER_DEFAULT_PARTITION_KEY_STRATEGY=domain-key
PRODUCER_ENABLE_SCHEMA_VALIDATION=true

# ------------------------------------------------------------
# Apache Flink
# ------------------------------------------------------------
FLINK_JOBMANAGER_HOST=jobmanager
FLINK_JOBMANAGER_PORT=8081
FLINK_TASKMANAGER_SLOTS=4
FLINK_DEFAULT_PARALLELISM=2
FLINK_CHECKPOINT_INTERVAL=30s
FLINK_CHECKPOINT_MODE=EXACTLY_ONCE
FLINK_WATERMARK_MAX_OUT_OF_ORDERNESS=30s
FLINK_RESTART_STRATEGY=fixed-delay
FLINK_RESTART_ATTEMPTS=3
FLINK_RESTART_DELAY=10s

FLINK_CHECKPOINTS_URI=s3://checkpoints/flink/
FLINK_SAVEPOINTS_URI=s3://checkpoints/savepoints/

# ------------------------------------------------------------
# Hive Metastore
# ------------------------------------------------------------
HIVE_METASTORE_HOST=hive-metastore
HIVE_METASTORE_PORT=9083
HIVE_METASTORE_URI=thrift://hive-metastore:9083

METASTORE_DB_HOST=postgres
METASTORE_DB_PORT=5432
METASTORE_DB_NAME=metastore
METASTORE_DB_USER=hive
METASTORE_DB_PASSWORD=hive

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=metastore
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive

# ------------------------------------------------------------
# MinIO / S3-compatible storage
# ------------------------------------------------------------
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1

S3_PATH_STYLE_ACCESS=true
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1

LAKEHOUSE_BUCKET=lakehouse
CHECKPOINTS_BUCKET=checkpoints

LAKEHOUSE_WAREHOUSE_URI=s3://lakehouse/warehouse/
BRONZE_PREFIX=warehouse/bronze
SILVER_PREFIX=warehouse/silver
GOLD_PREFIX=warehouse/gold

# ------------------------------------------------------------
# Apache Iceberg
# ------------------------------------------------------------
ICEBERG_CATALOG_NAME=lakehouse
ICEBERG_CATALOG_TYPE=hive_metastore
ICEBERG_WAREHOUSE=s3://lakehouse/warehouse/
ICEBERG_NAMESPACE_BRONZE=bronze
ICEBERG_NAMESPACE_SILVER=silver
ICEBERG_NAMESPACE_GOLD=gold

# ------------------------------------------------------------
# Trino
# ------------------------------------------------------------
TRINO_HOST=trino
TRINO_PORT=8080
TRINO_HTTP_URL=http://trino:8080
TRINO_CATALOG=iceberg
TRINO_SCHEMA_BRONZE=bronze
TRINO_SCHEMA_SILVER=silver
TRINO_SCHEMA_GOLD=gold
TRINO_USER=trino

# ------------------------------------------------------------
# Prometheus
# ------------------------------------------------------------
PROMETHEUS_HOST=prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# ------------------------------------------------------------
# Grafana
# ------------------------------------------------------------
GRAFANA_HOST=grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ALLOW_SIGN_UP=false

# ------------------------------------------------------------
# Databricks / Spark integration
# ------------------------------------------------------------
DATABRICKS_ENABLED=true
DATABRICKS_CATALOG=lakehouse
DATABRICKS_BRONZE_SCHEMA=bronze
DATABRICKS_SILVER_SCHEMA=silver
DATABRICKS_GOLD_SCHEMA=gold

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ------------------------------------------------------------
# Feature toggles
# ------------------------------------------------------------
ENABLE_KAFKA_UI=true
ENABLE_GRAFANA=true
ENABLE_PROMETHEUS=true
ENABLE_DATABRICKS_NOTEBOOKS=true